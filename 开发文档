### 6.2 核心WebSocket状态机逻辑 (`websocket/handler.py`)

```python
# 伪代码示意
async def handle_websocket(websocket: WebSocket, user_id: int):
    await websocket.accept()
    
    while True:
        msg = await websocket.receive()
        
        # 1. 接收开始录音信号
        if msg["type"] == "audio_start":
            asr_stream = asr_service.create_stream()
            
        # 2. 接收音频二进制流
        elif msg["type"] == "binary":
            asr_stream.feed(msg["bytes"])
            partial_text = asr_stream.get_partial()
            await websocket.send_json({"type": "asr_partial", "payload": {"text": partial_text}})
            
        # 3. 接收结束录音信号，开始Agent处理
        elif msg["type"] == "audio_end":
            final_text = asr_stream.finalize()
            await websocket.send_json({"type": "asr_final", "payload": {"text": final_text}})
            
            # 构造上下文，调用Agent
            agent_input = build_agent_input(user_id, final_text)
            agent_output = agent.adapter.run(agent_input) 
            
            # 4. 处理Agent输出 - 行程同步
            if agent_output.action_type in ['create_event', 'update_event']:
                is_conflict = event_engine.check_conflict(user_id, agent_output.event_data)
                if is_conflict:
                    # 让Agent重新规划或修改状态为tentative
                    pass
                save_to_db(agent_output.event_data)
                await websocket.send_json({"type": "event_upsert", "payload": agent_output.event_data})
                
            # 5. 处理Agent输出 - 语音回复 (后端TTS)
            if agent_output.text_response:
                # 流式TTS
                async for audio_chunk in tts_service.stream(agent_output.text_response):
                    await websocket.send_bytes(audio_chunk) # 发送音频二进制
                await websocket.send_json({"type": "agent_audio_done"})
```

